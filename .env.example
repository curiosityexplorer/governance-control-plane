# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to git (it's in .gitignore)

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini            # gpt-4o for higher quality, costs ~10x more
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT=60

# ── Experiment settings ───────────────────────────────────────────────────────
RUNS_PER_TASK=10                    # Paper uses 10; set to 2 for smoke tests
MAX_AGENT_TURNS=15                  # Maximum turns per task before timeout
TEMPERATURE=0.7                     # LLM temperature (paper default)

# ── AgentBench connection ─────────────────────────────────────────────────────
AGENTBENCH_OS_HOST=localhost
AGENTBENCH_OS_PORT=5001
AGENTBENCH_DB_HOST=localhost
AGENTBENCH_DB_PORT=5002
AGENTBENCH_WEB_HOST=localhost
AGENTBENCH_WEB_PORT=5003

# ── Governance settings ───────────────────────────────────────────────────────
HITL_MODE=auto                      # auto=approve-all for batch runs, interactive=prompt human
HITL_TIMEOUT_SECONDS=30             # Max wait for human approval (auto-deny if exceeded)
INJECTION_SCAN_THRESHOLD=0.7        # 0.0-1.0; higher = stricter detection
POLICY_ENGINE_TIMEOUT_MS=100        # Max ms for policy decision (enforced)
SANDBOX_NETWORK_ALLOWLIST=          # Comma-separated allowed hosts (empty = none)

# ── Output ────────────────────────────────────────────────────────────────────
RESULTS_DIR=./results
LOG_LEVEL=INFO                      # DEBUG for verbose trace output
SAVE_FULL_TRACES=true               # Save per-episode trace JSON (uses ~50MB for full run)
